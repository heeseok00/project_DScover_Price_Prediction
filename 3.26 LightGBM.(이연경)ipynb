    "\"\"\"\n",
    "데이터·AI를 활용한 물가 예측 경진대회 : 농산물 가격을 중심으로\n",
    "DACON 236381 — LightGBM v2 (개선판)\n",
    "\n",
    "주요 개선사항\n",
    "  1. 전년 동기 가격 피처 추가 (yoy_lag_36)\n",
    "  2. 평년 평균가격 피처 활용\n",
    "  3. T+2, T+3 예측 시 이전 예측값을 lag에 반영 (롤링 예측)\n",
    "  4. 품목별 개별 모델 학습\n",
    "\"\"\"\n",
    "\n",
    "import os, warnings\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import lightgbm as lgb\n",
    "from sklearn.model_selection import KFold\n",
    "\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "np.random.seed(42)\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 0. 경로 & 상수\n",
    "# ──────────────────────────────────────────────────\n",
    "DATA_DIR = \".\"\n",
    "SUB_PATH = f\"{DATA_DIR}/sample_submission.csv\"\n",
    "\n",
    "ENCODER_LEN = 9\n",
    "DECODER_LEN = 3\n",
    "N_SPLITS    = 5\n",
    "\n",
    "TARGET_ITEMS = {\n",
    "    \"배추\":         (\"가을배추\",       \"상품\"),\n",
    "    \"무\":           (\"가을무\",         \"상품\"),\n",
    "    \"양파\":         (\"양파\",           \"상품\"),\n",
    "    \"사과\":         (\"후지\",           \"상품\"),\n",
    "    \"배\":           (\"신고\",           \"상품\"),\n",
    "    \"건고추\":       (\"화건\",           \"상품\"),\n",
    "    \"깐마늘(국산)\": (\"깐마늘(국산)\",   \"상품\"),\n",
    "    \"감자\":         (\"감자 수미\",      \"상품\"),\n",
    "    \"대파\":         (\"대파(일반)\",     \"상품\"),\n",
    "    \"상추\":         (\"청상추\",         \"상품\"),\n",
    "}\n",
    "\n",
    "TARGET_ITEMS_TEST = {\n",
    "    \"배추\":         (\"배추\",           \"상\"),\n",
    "    \"무\":           (\"무\",             \"상\"),\n",
    "    \"양파\":         (\"양파\",           \"상\"),\n",
    "    \"사과\":         (\"후지\",           \"상품\"),\n",
    "    \"배\":           (\"신고\",           \"상품\"),\n",
    "    \"건고추\":       (\"화건\",           \"상품\"),\n",
    "    \"깐마늘(국산)\": (\"깐마늘(국산)\",   \"상품\"),\n",
    "    \"감자\":         (\"감자 수미\",      \"상\"),\n",
    "    \"대파\":         (\"대파(일반)\",     \"상\"),\n",
    "    \"상추\":         (\"청\",             \"상품\"),\n",
    "}\n",
    "\n",
    "LGBM_PARAMS = {\n",
    "    \"objective\":         \"regression\",\n",
    "    \"metric\":            \"mae\",\n",
    "    \"learning_rate\":     0.03,\n",
    "    \"num_leaves\":        31,\n",
    "    \"min_child_samples\": 3,\n",
    "    \"feature_fraction\":  0.8,\n",
    "    \"bagging_fraction\":  0.8,\n",
    "    \"bagging_freq\":      5,\n",
    "    \"reg_alpha\":         0.05,\n",
    "    \"reg_lambda\":        0.05,\n",
    "    \"verbose\":           -1,\n",
    "    \"random_state\":      42,\n",
    "}\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 1. 데이터 로드\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def load_csv(path):\n",
    "    for enc in [\"utf-8-sig\", \"cp949\", \"utf-8\"]:\n",
    "        try:\n",
    "            return pd.read_csv(path, encoding=enc)\n",
    "        except Exception:\n",
    "            continue\n",
    "    raise ValueError(f\"읽기 실패: {path}\")\n",
    "\n",
    "def load_train():      return load_csv(os.path.join(DATA_DIR, \"train.csv\"))\n",
    "def load_meta_train():\n",
    "    w = load_csv(os.path.join(DATA_DIR, \"TRAIN_전국도매_2018-2021.csv\"))\n",
    "    l = load_csv(os.path.join(DATA_DIR, \"TRAIN_산지공판장_2018-2021.csv\"))\n",
    "    return w, l\n",
    "def load_test(idx):    return load_csv(os.path.join(DATA_DIR, f\"TEST_{idx:02d}.csv\"))\n",
    "def load_meta_test(idx):\n",
    "    w = load_csv(os.path.join(DATA_DIR, \"meta\", f\"TEST_전국도매_{idx:02d}.csv\"))\n",
    "    l = load_csv(os.path.join(DATA_DIR, \"meta\", f\"TEST_산지공판장_{idx:02d}.csv\"))\n",
    "    return w, l\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 2. 전처리 유틸\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def parse_sijeom(df, col=\"시점\"):\n",
    "    decade_map = {\"상\": 1, \"중\": 2, \"하\": 3}\n",
    "    df = df.copy()\n",
    "    s  = df[col].astype(str).str.strip()\n",
    "    p1 = s.str.extract(r\"^(\\d{4})(\\d{2})(상|중|하)순$\")\n",
    "    p2 = s.str.extract(r\"(\\d{4})년\\s*(\\d{1,2})월\\s*(상|중|하)순\")\n",
    "    year  = p1[0].fillna(p2[0])\n",
    "    month = p1[1].fillna(p2[1])\n",
    "    dec   = p1[2].fillna(p2[2])\n",
    "    df[\"연도\"]     = year.astype(float).astype(\"Int64\")\n",
    "    df[\"월\"]       = month.astype(float).astype(\"Int64\")\n",
    "    df[\"순\"]       = dec.map(decade_map)\n",
    "    df[\"time_idx\"] = (df[\"연도\"] - 2018) * 36 + (df[\"월\"] - 1) * 3 + df[\"순\"] - 1\n",
    "    return df\n",
    "\n",
    "def fix_missing(series):\n",
    "    s = series.copy().astype(float)\n",
    "    s[s == 0] = np.nan\n",
    "    return s.interpolate(method=\"linear\").ffill().bfill()\n",
    "\n",
    "def build_meta_feature(wholesale_df, local_df):\n",
    "    frames = []\n",
    "    for df, name in [(wholesale_df, \"도매\"), (local_df, \"산지\")]:\n",
    "        df = df.copy()\n",
    "        df.columns = df.columns.str.strip()\n",
    "        if \"시점\" in df.columns:\n",
    "            df = parse_sijeom(df)\n",
    "        price_col = next((c for c in df.columns if \"평균가\" in c or \"경락\" in c), None)\n",
    "        if price_col is None:\n",
    "            continue\n",
    "        df[price_col] = fix_missing(df[price_col])\n",
    "        agg = (df.groupby([\"연도\", \"월\", \"순\", \"품목명\"])[price_col]\n",
    "                 .mean().reset_index()\n",
    "                 .rename(columns={\"품목명\": \"item_key\", price_col: f\"{name}_price\"}))\n",
    "        frames.append(agg)\n",
    "    if not frames:\n",
    "        return pd.DataFrame()\n",
    "    out = frames[0]\n",
    "    for f in frames[1:]:\n",
    "        out = out.merge(f, on=[\"연도\", \"월\", \"순\", \"item_key\"], how=\"outer\")\n",
    "    return out\n",
    "\n",
    "def add_features(df):\n",
    "    \"\"\"Lag / Rolling / 계절성 / 전년동기 피처\"\"\"\n",
    "    df = df.sort_values([\"item_key\", \"time_idx\"]).reset_index(drop=True)\n",
    "\n",
    "    # 단기 Lag\n",
    "    for lag in [1, 2, 3, 6, 9]:\n",
    "        df[f\"lag_{lag}\"] = df.groupby(\"item_key\")[\"평균가격(원)\"].shift(lag)\n",
    "\n",
    "    # 전년 동기 (36순 = 1년)\n",
    "    df[\"lag_36\"] = df.groupby(\"item_key\")[\"평균가격(원)\"].shift(36)\n",
    "    # 전년 동기 대비 변화율\n",
    "    df[\"yoy_ratio\"] = df[\"평균가격(원)\"] / (df[\"lag_36\"] + 1e-8)\n",
    "\n",
    "    # Rolling 통계\n",
    "    for w in [3, 6, 9]:\n",
    "        df[f\"roll_mean_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).mean()))\n",
    "        df[f\"roll_std_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).std().fillna(0)))\n",
    "        df[f\"roll_max_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).max()))\n",
    "        df[f\"roll_min_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).min()))\n",
    "\n",
    "    # 추세 피처 (lag_1 - lag_3)\n",
    "    df[\"trend_short\"] = df[\"lag_1\"] - df[\"lag_3\"]\n",
    "    df[\"trend_long\"]  = df[\"lag_3\"] - df[\"lag_9\"]\n",
    "\n",
    "    # 계절성\n",
    "    df[\"sin_month\"]  = np.sin(2 * np.pi * df[\"월\"].astype(float) / 12)\n",
    "    df[\"cos_month\"]  = np.cos(2 * np.pi * df[\"월\"].astype(float) / 12)\n",
    "    df[\"sin_decade\"] = np.sin(2 * np.pi * df[\"순\"].astype(float) / 3)\n",
    "    df[\"cos_decade\"] = np.cos(2 * np.pi * df[\"순\"].astype(float) / 3)\n",
    "\n",
    "    return df\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 3. Train 전처리\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def preprocess_train(train_raw, wholesale_raw, local_raw):\n",
    "    df = train_raw.copy()\n",
    "    df.columns = df.columns.str.strip()\n",
    "    if \"시점\" in df.columns:\n",
    "        df = parse_sijeom(df)\n",
    "\n",
    "    grade_col = \"등급명\" if \"등급명\" in df.columns else \"등급\"\n",
    "    records = []\n",
    "    for item_name, (variety, grade) in TARGET_ITEMS.items():\n",
    "        mask = ((df[\"품목명\"] == item_name) &\n",
    "                (df[\"품종명\"] == variety) &\n",
    "                (df[grade_col] == grade))\n",
    "        sub = df[mask].copy()\n",
    "        sub[\"item_key\"] = item_name\n",
    "        records.append(sub)\n",
    "    df = pd.concat(records, ignore_index=True)\n",
    "\n",
    "    # 평년 평균가격 결측 처리\n",
    "    if \"평년 평균가격(원)\" in df.columns:\n",
    "        df[\"평년 평균가격(원)\"] = df.groupby(\"item_key\")[\"평년 평균가격(원)\"].transform(fix_missing)\n",
    "\n",
    "    df[\"평균가격(원)\"] = df.groupby(\"item_key\")[\"평균가격(원)\"].transform(fix_missing)\n",
    "\n",
    "    # 메타 merge\n",
    "    meta = build_meta_feature(wholesale_raw, local_raw)\n",
    "    if not meta.empty:\n",
    "        df = df.merge(meta, on=[\"연도\", \"월\", \"순\", \"item_key\"], how=\"left\")\n",
    "\n",
    "    df = add_features(df)\n",
    "    return df\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 4. 피처 컬럼 정의\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "FEAT_COLS = [\n",
    "    \"lag_1\", \"lag_2\", \"lag_3\", \"lag_6\", \"lag_9\", \"lag_36\",\n",
    "    \"yoy_ratio\",\n",
    "    \"roll_mean_3\", \"roll_mean_6\", \"roll_mean_9\",\n",
    "    \"roll_std_3\",  \"roll_std_6\",  \"roll_std_9\",\n",
    "    \"roll_max_3\",  \"roll_max_6\",  \"roll_max_9\",\n",
    "    \"roll_min_3\",  \"roll_min_6\",  \"roll_min_9\",\n",
    "    \"trend_short\", \"trend_long\",\n",
    "    \"sin_month\", \"cos_month\", \"sin_decade\", \"cos_decade\",\n",
    "    \"도매_price\", \"산지_price\",\n",
    "    \"평년 평균가격(원)\",\n",
    "    \"월\", \"순\", \"연도\",\n",
    "]\n",
    "\n",
    "def get_feat_cols(df):\n",
    "    return [c for c in FEAT_COLS if c in df.columns]\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 5. 학습 샘플 생성\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def make_supervised(df, feat_cols, horizon):\n",
    "    \"\"\"T 시점 피처로 T+horizon 가격 예측하는 샘플 생성\"\"\"\n",
    "    X_list, y_list = [], []\n",
    "    item_keys = list(TARGET_ITEMS.keys())\n",
    "\n",
    "    for item_key, grp in df.groupby(\"item_key\"):\n",
    "        grp    = grp.sort_values(\"time_idx\").reset_index(drop=True)\n",
    "        prices = grp[\"평균가격(원)\"].values\n",
    "        feats  = grp[feat_cols].fillna(0).values.astype(float)\n",
    "        item_enc = item_keys.index(item_key)\n",
    "        n = len(grp)\n",
    "\n",
    "        for i in range(ENCODER_LEN - 1, n - horizon):\n",
    "            target = prices[i + horizon]\n",
    "            if np.isnan(target):\n",
    "                continue\n",
    "            row = np.append(feats[i], item_enc)\n",
    "            X_list.append(row)\n",
    "            y_list.append(target)\n",
    "\n",
    "    return np.array(X_list), np.array(y_list)\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 6. LightGBM 학습 (품목별 × horizon별)\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def train_lgbm_single(X, y, label=\"\"):\n",
    "    \"\"\"KFold OOF 학습, 모델 리스트 반환\"\"\"\n",
    "    kf     = KFold(n_splits=N_SPLITS, shuffle=True, random_state=42)\n",
    "    models = []\n",
    "    oof    = np.zeros(len(y))\n",
    "\n",
    "    for fold, (tr_idx, val_idx) in enumerate(kf.split(X)):\n",
    "        dtrain = lgb.Dataset(X[tr_idx], label=y[tr_idx])\n",
    "        dval   = lgb.Dataset(X[val_idx], label=y[val_idx], reference=dtrain)\n",
    "        model  = lgb.train(\n",
    "            LGBM_PARAMS, dtrain,\n",
    "            num_boost_round=2000,\n",
    "            valid_sets=[dval],\n",
    "            callbacks=[\n",
    "                lgb.early_stopping(stopping_rounds=50, verbose=False),\n",
    "                lgb.log_evaluation(period=-1),\n",
    "            ],\n",
    "        )\n",
    "        oof[val_idx] = model.predict(X[val_idx])\n",
    "        models.append(model)\n",
    "\n",
    "    nmae_val = np.mean(np.abs(y - oof) / (np.abs(y) + 1e-8))\n",
    "    print(f\"    {label} OOF NMAE: {nmae_val:.5f}\")\n",
    "    return models\n",
    "\n",
    "def ensemble_predict(models, X):\n",
    "    return np.mean([m.predict(X) for m in models], axis=0)\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 7. TEST 전처리\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def preprocess_test_single(test_raw, wholesale_raw, local_raw):\n",
    "    df = test_raw.copy()\n",
    "    df.columns = df.columns.str.strip()\n",
    "\n",
    "    def rel_idx(s):\n",
    "        s = str(s).strip()\n",
    "        if s == \"T순\": return 8\n",
    "        m = pd.Series([s]).str.extract(r\"T-(\\d+)순\")[0]\n",
    "        return 8 - int(m.iloc[0]) if pd.notna(m.iloc[0]) else np.nan\n",
    "\n",
    "    df[\"time_idx\"] = df[\"시점\"].apply(rel_idx)\n",
    "    df[\"연도\"] = pd.NA; df[\"월\"] = pd.NA; df[\"순\"] = pd.NA\n",
    "\n",
    "    grade_col = \"등급명\" if \"등급명\" in df.columns else \"등급\"\n",
    "    records = []\n",
    "    for item_name, (variety, grade) in TARGET_ITEMS_TEST.items():\n",
    "        mask = ((df[\"품목명\"] == item_name) &\n",
    "                (df[\"품종명\"] == variety) &\n",
    "                (df[grade_col] == grade))\n",
    "        sub = df[mask].copy()\n",
    "        sub[\"item_key\"] = item_name\n",
    "        records.append(sub)\n",
    "\n",
    "    non_empty = [r for r in records if len(r) > 0]\n",
    "    if not non_empty:\n",
    "        return pd.DataFrame()\n",
    "    df = pd.concat(non_empty, ignore_index=True)\n",
    "\n",
    "    if \"평년 평균가격(원)\" in df.columns:\n",
    "        df[\"평년 평균가격(원)\"] = df.groupby(\"item_key\")[\"평년 평균가격(원)\"].transform(fix_missing)\n",
    "    df[\"평균가격(원)\"] = df.groupby(\"item_key\")[\"평균가격(원)\"].transform(fix_missing)\n",
    "\n",
    "    # 메타: 품목별 전체 평균\n",
    "    meta = build_meta_feature(wholesale_raw, local_raw)\n",
    "    if not meta.empty:\n",
    "        price_cols = [c for c in [\"도매_price\", \"산지_price\"] if c in meta.columns]\n",
    "        if price_cols:\n",
    "            meta_avg = meta.groupby(\"item_key\")[price_cols].mean().reset_index()\n",
    "            df = df.merge(meta_avg, on=\"item_key\", how=\"left\")\n",
    "\n",
    "    # Lag / Rolling\n",
    "    df = df.sort_values([\"item_key\", \"time_idx\"]).reset_index(drop=True)\n",
    "    for lag in [1, 2, 3, 6, 9]:\n",
    "        df[f\"lag_{lag}\"] = df.groupby(\"item_key\")[\"평균가격(원)\"].shift(lag)\n",
    "    df[\"lag_36\"]   = np.nan   # test에서 전년 데이터 없음 → 0 처리\n",
    "    df[\"yoy_ratio\"] = np.nan\n",
    "    for w in [3, 6, 9]:\n",
    "        df[f\"roll_mean_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).mean()))\n",
    "        df[f\"roll_std_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).std().fillna(0)))\n",
    "        df[f\"roll_max_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).max()))\n",
    "        df[f\"roll_min_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).min()))\n",
    "    df[\"trend_short\"] = df[\"lag_1\"] - df[\"lag_3\"]\n",
    "    df[\"trend_long\"]  = df[\"lag_3\"] - df[\"lag_9\"]\n",
    "    df[\"sin_month\"]  = np.sin(2 * np.pi * 6 / 12)\n",
    "    df[\"cos_month\"]  = np.cos(2 * np.pi * 6 / 12)\n",
    "    df[\"sin_decade\"] = np.sin(2 * np.pi * 2 / 3)\n",
    "    df[\"cos_decade\"] = np.cos(2 * np.pi * 2 / 3)\n",
    "\n",
    "    return df\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 8. TEST 추론 (롤링 예측)\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def predict_test(models_by_horizon, test_df, train_df, feat_cols):\n",
    "    \"\"\"\n",
    "    롤링 예측:\n",
    "      T+1 예측 → T+2 예측 시 T+1 예측값을 lag_1로 반영\n",
    "               → T+3 예측 시 T+1, T+2 예측값도 lag 반영\n",
    "    \"\"\"\n",
    "    item_keys = list(TARGET_ITEMS.keys())\n",
    "    preds = {}\n",
    "\n",
    "    for item_key in item_keys:\n",
    "        item_enc  = item_keys.index(item_key)\n",
    "        test_item = (test_df[test_df[\"item_key\"] == item_key].sort_values(\"time_idx\")\n",
    "                     if len(test_df) > 0 else pd.DataFrame())\n",
    "        train_item = train_df[train_df[\"item_key\"] == item_key].sort_values(\"time_idx\")\n",
    "\n",
    "        # 최근 가격 시계열 (train 끝 + test)\n",
    "        if len(test_item) > 0:\n",
    "            recent_prices = test_item[\"평균가격(원)\"].fillna(0).tolist()\n",
    "        else:\n",
    "            recent_prices = train_item[\"평균가격(원)\"].fillna(0).tail(9).tolist()\n",
    "\n",
    "        # 기준 피처 행 (T순 = 마지막)\n",
    "        if len(test_item) > 0:\n",
    "            base_row = test_item.iloc[[-1]].copy()\n",
    "        else:\n",
    "            base_row = train_item.iloc[[-1]].copy()\n",
    "\n",
    "        pred_list = []\n",
    "        pred_prices = []  # 예측된 미래 가격 누적\n",
    "\n",
    "        for horizon in [1, 2, 3]:\n",
    "            row = base_row.copy()\n",
    "\n",
    "            # 롤링 예측: 이전 예측값을 lag에 반영\n",
    "            extended = recent_prices + pred_prices\n",
    "            if len(extended) >= 1:\n",
    "                row[\"lag_1\"] = extended[-1]\n",
    "            if len(extended) >= 2:\n",
    "                row[\"lag_2\"] = extended[-2]\n",
    "            if len(extended) >= 3:\n",
    "                row[\"lag_3\"] = extended[-3]\n",
    "\n",
    "            # rolling 재계산\n",
    "            for w_size in [3, 6, 9]:\n",
    "                tail = extended[-w_size:] if len(extended) >= w_size else extended\n",
    "                row[f\"roll_mean_{w_size}\"] = np.mean(tail) if tail else 0\n",
    "                row[f\"roll_std_{w_size}\"]  = np.std(tail)  if tail else 0\n",
    "                row[f\"roll_max_{w_size}\"]  = np.max(tail)  if tail else 0\n",
    "                row[f\"roll_min_{w_size}\"]  = np.min(tail)  if tail else 0\n",
    "\n",
    "            row[\"trend_short\"] = row[\"lag_1\"].values[0] - (row[\"lag_3\"].values[0] if \"lag_3\" in row else 0)\n",
    "            row[\"trend_long\"]  = (row[\"lag_3\"].values[0] if \"lag_3\" in row else 0) - (row[\"lag_9\"].values[0] if \"lag_9\" in row else 0)\n",
    "\n",
    "            # 피처 벡터 생성\n",
    "            feat_vec = []\n",
    "            for c in feat_cols:\n",
    "                val = row[c].values[0] if c in row.columns else 0.0\n",
    "                try:    val = float(val)\n",
    "                except: val = 0.0\n",
    "                if np.isnan(val) or np.isinf(val):\n",
    "                    val = 0.0\n",
    "                feat_vec.append(val)\n",
    "            feat_vec.append(item_enc)\n",
    "\n",
    "            X = np.array(feat_vec).reshape(1, -1)\n",
    "            pred_val = float(np.mean([m.predict(X)[0] for m in models_by_horizon[horizon]]))\n",
    "            pred_val = max(pred_val, 0)\n",
    "\n",
    "            pred_list.append(pred_val)\n",
    "            pred_prices.append(pred_val)\n",
    "\n",
    "        preds[item_key] = pred_list\n",
    "\n",
    "    return preds\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 9. 메인\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def main():\n",
    "    print(\"=\" * 55)\n",
    "    print(\"  농산물 가격 예측 — LightGBM v2\")\n",
    "    print(\"=\" * 55)\n",
    "\n",
    "    # 1. 로드\n",
    "    print(\"\\n[1/5] 데이터 로드 중...\")\n",
    "    train_raw        = load_train()\n",
    "    w_train, l_train = load_meta_train()\n",
    "\n",
    "    # 2. 전처리\n",
    "    print(\"[2/5] 전처리 중...\")\n",
    "    train_df  = preprocess_train(train_raw, w_train, l_train)\n",
    "    feat_cols = get_feat_cols(train_df)\n",
    "    print(f\"      피처 {len(feat_cols)}개\")\n",
    "    print(f\"      학습 행 수: {len(train_df)}\")\n",
    "\n",
    "    # 3. 학습\n",
    "    print(\"\\n[3/5] LightGBM 학습 중...\")\n",
