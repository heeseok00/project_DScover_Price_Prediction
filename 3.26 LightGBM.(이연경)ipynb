   "source": [
    "\"\"\"\n",
    "데이터·AI를 활용한 물가 예측 경진대회 : 농산물 가격을 중심으로\n",
    "DACON 236381 — LightGBM 버전\n",
    "\n",
    "파이프라인\n",
    "  1. 데이터 로드\n",
    "  2. 전처리 (결측치·피처 엔지니어링·메타 merge)\n",
    "  3. 품목별 × 예측순(T+1/T+2/T+3) 개별 LightGBM 학습\n",
    "  4. TEST 추론 → submission.csv 저장\n",
    "\"\"\"\n",
    "\n",
    "import os, warnings\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import lightgbm as lgb\n",
    "from sklearn.model_selection import KFold\n",
    "\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "np.random.seed(42)\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 0. 경로 & 상수\n",
    "# ──────────────────────────────────────────────────\n",
    "DATA_DIR = \".\"          # 노트북과 csv 파일이 같은 폴더\n",
    "SUB_PATH = f\"{DATA_DIR}/sample_submission.csv\"\n",
    "\n",
    "ENCODER_LEN = 9    # look-back: 최대 3개월(9순)\n",
    "DECODER_LEN = 3    # 예측: T+1, T+2, T+3순\n",
    "N_SPLITS    = 5    # KFold\n",
    "\n",
    "# 예측 대상 — train 기준 품종/등급\n",
    "TARGET_ITEMS = {\n",
    "    \"배추\":         (\"가을배추\",       \"상품\"),\n",
    "    \"무\":           (\"가을무\",         \"상품\"),\n",
    "    \"양파\":         (\"양파\",           \"상품\"),\n",
    "    \"사과\":         (\"후지\",           \"상품\"),\n",
    "    \"배\":           (\"신고\",           \"상품\"),\n",
    "    \"건고추\":       (\"화건\",           \"상품\"),\n",
    "    \"깐마늘(국산)\": (\"깐마늘(국산)\",   \"상품\"),\n",
    "    \"감자\":         (\"감자 수미\",      \"상품\"),\n",
    "    \"대파\":         (\"대파(일반)\",     \"상품\"),\n",
    "    \"상추\":         (\"청상추\",         \"상품\"),\n",
    "}\n",
    "\n",
    "# 예측 대상 — test 기준 품종/등급 (train과 다름)\n",
    "TARGET_ITEMS_TEST = {\n",
    "    \"배추\":         (\"배추\",           \"상\"),\n",
    "    \"무\":           (\"무\",             \"상\"),\n",
    "    \"양파\":         (\"양파\",           \"상\"),\n",
    "    \"사과\":         (\"후지\",           \"상품\"),\n",
    "    \"배\":           (\"신고\",           \"상품\"),\n",
    "    \"건고추\":       (\"화건\",           \"상품\"),\n",
    "    \"깐마늘(국산)\": (\"깐마늘(국산)\",   \"상품\"),\n",
    "    \"감자\":         (\"감자 수미\",      \"상\"),\n",
    "    \"대파\":         (\"대파(일반)\",     \"상\"),\n",
    "    \"상추\":         (\"청\",             \"상품\"),\n",
    "}\n",
    "\n",
    "LGBM_PARAMS = {\n",
    "    \"objective\":        \"regression\",\n",
    "    \"metric\":           \"mae\",\n",
    "    \"learning_rate\":    0.05,\n",
    "    \"num_leaves\":       31,\n",
    "    \"min_child_samples\": 5,\n",
    "    \"feature_fraction\": 0.8,\n",
    "    \"bagging_fraction\": 0.8,\n",
    "    \"bagging_freq\":     5,\n",
    "    \"reg_alpha\":        0.1,\n",
    "    \"reg_lambda\":       0.1,\n",
    "    \"verbose\":          -1,\n",
    "    \"random_state\":     42,\n",
    "}\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 1. 데이터 로드\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def load_csv(path):\n",
    "    for enc in [\"utf-8-sig\", \"cp949\", \"utf-8\"]:\n",
    "        try:\n",
    "            return pd.read_csv(path, encoding=enc)\n",
    "        except Exception:\n",
    "            continue\n",
    "    raise ValueError(f\"읽기 실패: {path}\")\n",
    "\n",
    "def load_train():\n",
    "    return load_csv(os.path.join(DATA_DIR, \"train.csv\"))\n",
    "\n",
    "def load_meta_train():\n",
    "    w = load_csv(os.path.join(DATA_DIR, \"TRAIN_전국도매_2018-2021.csv\"))\n",
    "    l = load_csv(os.path.join(DATA_DIR, \"TRAIN_산지공판장_2018-2021.csv\"))\n",
    "    return w, l\n",
    "\n",
    "def load_test(idx):\n",
    "    return load_csv(os.path.join(DATA_DIR, f\"TEST_{idx:02d}.csv\"))\n",
    "\n",
    "def load_meta_test(idx):\n",
    "    w = load_csv(os.path.join(DATA_DIR, \"meta\", f\"TEST_전국도매_{idx:02d}.csv\"))\n",
    "    l = load_csv(os.path.join(DATA_DIR, \"meta\", f\"TEST_산지공판장_{idx:02d}.csv\"))\n",
    "    return w, l\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 2. 전처리 유틸\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def parse_sijeom(df, col=\"시점\"):\n",
    "    \"\"\"'201801상순' 또는 '2018년 1월 상순' → 연도·월·순·time_idx\"\"\"\n",
    "    decade_map = {\"상\": 1, \"중\": 2, \"하\": 3}\n",
    "    df = df.copy()\n",
    "    s  = df[col].astype(str).str.strip()\n",
    "    p1 = s.str.extract(r\"^(\\d{4})(\\d{2})(상|중|하)순$\")\n",
    "    p2 = s.str.extract(r\"(\\d{4})년\\s*(\\d{1,2})월\\s*(상|중|하)순\")\n",
    "    year  = p1[0].fillna(p2[0])\n",
    "    month = p1[1].fillna(p2[1])\n",
    "    dec   = p1[2].fillna(p2[2])\n",
    "    df[\"연도\"]     = year.astype(float).astype(\"Int64\")\n",
    "    df[\"월\"]       = month.astype(float).astype(\"Int64\")\n",
    "    df[\"순\"]       = dec.map(decade_map)\n",
    "    df[\"time_idx\"] = (df[\"연도\"] - 2018) * 36 + (df[\"월\"] - 1) * 3 + df[\"순\"] - 1\n",
    "    return df\n",
    "\n",
    "def fix_missing(series):\n",
    "    \"\"\"0 → NaN → 선형보간 → ffill/bfill\"\"\"\n",
    "    s = series.copy().astype(float)\n",
    "    s[s == 0] = np.nan\n",
    "    s = s.interpolate(method=\"linear\").ffill().bfill()\n",
    "    return s\n",
    "\n",
    "def build_meta_feature(wholesale_df, local_df):\n",
    "    \"\"\"메타 데이터 → 품목별 (연도·월·순) 평균가 집계\"\"\"\n",
    "    frames = []\n",
    "    for df, name in [(wholesale_df, \"도매\"), (local_df, \"산지\")]:\n",
    "        df = df.copy()\n",
    "        df.columns = df.columns.str.strip()\n",
    "        if \"시점\" in df.columns:\n",
    "            df = parse_sijeom(df)\n",
    "        price_col = next((c for c in df.columns if \"평균가\" in c or \"경락\" in c), None)\n",
    "        if price_col is None:\n",
    "            continue\n",
    "        df[price_col] = fix_missing(df[price_col])\n",
    "        agg = (df.groupby([\"연도\", \"월\", \"순\", \"품목명\"])[price_col]\n",
    "                 .mean().reset_index()\n",
    "                 .rename(columns={\"품목명\": \"item_key\", price_col: f\"{name}_price\"}))\n",
    "        frames.append(agg)\n",
    "    if not frames:\n",
    "        return pd.DataFrame()\n",
    "    out = frames[0]\n",
    "    for f in frames[1:]:\n",
    "        out = out.merge(f, on=[\"연도\", \"월\", \"순\", \"item_key\"], how=\"outer\")\n",
    "    return out\n",
    "\n",
    "def add_lag_rolling(df):\n",
    "    \"\"\"Lag / Rolling / 계절성 피처\"\"\"\n",
    "    df = df.sort_values([\"item_key\", \"time_idx\"]).reset_index(drop=True)\n",
    "    for lag in [1, 2, 3, 6, 9]:\n",
    "        df[f\"lag_{lag}\"] = df.groupby(\"item_key\")[\"평균가격(원)\"].shift(lag)\n",
    "    for w in [3, 6, 9]:\n",
    "        df[f\"roll_mean_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).mean()))\n",
    "        df[f\"roll_std_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).std().fillna(0)))\n",
    "    df[\"sin_month\"]  = np.sin(2 * np.pi * df[\"월\"].astype(float)  / 12)\n",
    "    df[\"cos_month\"]  = np.cos(2 * np.pi * df[\"월\"].astype(float)  / 12)\n",
    "    df[\"sin_decade\"] = np.sin(2 * np.pi * df[\"순\"].astype(float)  / 3)\n",
    "    df[\"cos_decade\"] = np.cos(2 * np.pi * df[\"순\"].astype(float)  / 3)\n",
    "    return df\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 3. Train 전처리\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def preprocess_train(train_raw, wholesale_raw, local_raw):\n",
    "    df = train_raw.copy()\n",
    "    df.columns = df.columns.str.strip()\n",
    "    if \"시점\" in df.columns:\n",
    "        df = parse_sijeom(df)\n",
    "\n",
    "    grade_col = \"등급명\" if \"등급명\" in df.columns else \"등급\"\n",
    "    records = []\n",
    "    for item_name, (variety, grade) in TARGET_ITEMS.items():\n",
    "        mask = ((df[\"품목명\"] == item_name) &\n",
    "                (df[\"품종명\"] == variety) &\n",
    "                (df[grade_col] == grade))\n",
    "        sub = df[mask].copy()\n",
    "        sub[\"item_key\"] = item_name\n",
    "        records.append(sub)\n",
    "    df = pd.concat(records, ignore_index=True)\n",
    "\n",
    "    df[\"평균가격(원)\"] = df.groupby(\"item_key\")[\"평균가격(원)\"].transform(fix_missing)\n",
    "\n",
    "    # 메타 merge\n",
    "    meta = build_meta_feature(wholesale_raw, local_raw)\n",
    "    if not meta.empty:\n",
    "        df = df.merge(meta, on=[\"연도\", \"월\", \"순\", \"item_key\"], how=\"left\")\n",
    "\n",
    "    df = add_lag_rolling(df)\n",
    "    return df\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 4. 학습 샘플 생성 (슬라이딩 윈도우)\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "FEAT_COLS = [\n",
    "    \"lag_1\", \"lag_2\", \"lag_3\", \"lag_6\", \"lag_9\",\n",
    "    \"roll_mean_3\", \"roll_mean_6\", \"roll_mean_9\",\n",
    "    \"roll_std_3\",  \"roll_std_6\",  \"roll_std_9\",\n",
    "    \"sin_month\", \"cos_month\", \"sin_decade\", \"cos_decade\",\n",
    "    \"도매_price\", \"산지_price\",\n",
    "    \"월\", \"순\", \"연도\",\n",
    "]\n",
    "\n",
    "def get_feat_cols(df):\n",
    "    return [c for c in FEAT_COLS if c in df.columns]\n",
    "\n",
    "def make_supervised(df, feat_cols, horizon):\n",
    "    \"\"\"\n",
    "    horizon = 1, 2, 3 (T+horizon순 예측)\n",
    "    반환: X [n_samples, n_features], y [n_samples]\n",
    "    \"\"\"\n",
    "    X_list, y_list = [], []\n",
    "    for item_key, grp in df.groupby(\"item_key\"):\n",
    "        grp = grp.sort_values(\"time_idx\").reset_index(drop=True)\n",
    "        prices = grp[\"평균가격(원)\"].values\n",
    "        feats  = grp[feat_cols].values.astype(float)\n",
    "        n = len(grp)\n",
    "        for i in range(ENCODER_LEN - 1, n - horizon):\n",
    "            # 현재 시점 피처 사용\n",
    "            row_feat = feats[i].copy()\n",
    "            # 품목 인코딩 추가\n",
    "            item_enc = list(TARGET_ITEMS.keys()).index(item_key)\n",
    "            row = np.append(row_feat, item_enc)\n",
    "            target = prices[i + horizon]\n",
    "            if np.isnan(target):\n",
    "                continue\n",
    "            X_list.append(row)\n",
    "            y_list.append(target)\n",
    "    return np.array(X_list), np.array(y_list)\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 5. LightGBM 학습 (KFold OOF)\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def train_lgbm(X, y, horizon):\n",
    "    \"\"\"KFold OOF 학습, 모델 리스트 반환\"\"\"\n",
    "    kf     = KFold(n_splits=N_SPLITS, shuffle=True, random_state=42)\n",
    "    models = []\n",
    "    oof    = np.zeros(len(y))\n",
    "\n",
    "    for fold, (tr_idx, val_idx) in enumerate(kf.split(X)):\n",
    "        X_tr, X_val = X[tr_idx], X[val_idx]\n",
    "        y_tr, y_val = y[tr_idx], y[val_idx]\n",
    "\n",
    "        dtrain = lgb.Dataset(X_tr, label=y_tr)\n",
    "        dval   = lgb.Dataset(X_val, label=y_val, reference=dtrain)\n",
    "\n",
    "        model = lgb.train(\n",
    "            LGBM_PARAMS,\n",
    "            dtrain,\n",
    "            num_boost_round=1000,\n",
    "            valid_sets=[dval],\n",
    "            callbacks=[\n",
    "                lgb.early_stopping(stopping_rounds=50, verbose=False),\n",
    "                lgb.log_evaluation(period=-1),\n",
    "            ],\n",
    "        )\n",
    "        oof[val_idx] = model.predict(X_val)\n",
    "        models.append(model)\n",
    "\n",
    "    nmae_score = np.mean(np.abs(y - oof) / (np.abs(y) + 1e-8))\n",
    "    print(f\"    T+{horizon}순 OOF NMAE: {nmae_score:.5f}\")\n",
    "    return models\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 6. TEST 전처리\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def preprocess_test_single(test_raw, wholesale_raw, local_raw):\n",
    "    df = test_raw.copy()\n",
    "    df.columns = df.columns.str.strip()\n",
    "\n",
    "    # 상대 시점 파싱 ('T-8순'=0 ~ 'T순'=8)\n",
    "    def rel_idx(s):\n",
    "        s = str(s).strip()\n",
    "        if s == \"T순\":\n",
    "            return 8\n",
    "        m = pd.Series([s]).str.extract(r\"T-(\\d+)순\")[0]\n",
    "        return 8 - int(m.iloc[0]) if pd.notna(m.iloc[0]) else np.nan\n",
    "\n",
    "    df[\"time_idx\"] = df[\"시점\"].apply(rel_idx)\n",
    "    df[\"연도\"] = pd.NA\n",
    "    df[\"월\"]   = pd.NA\n",
    "    df[\"순\"]   = pd.NA\n",
    "\n",
    "    grade_col = \"등급명\" if \"등급명\" in df.columns else \"등급\"\n",
    "    records = []\n",
    "    for item_name, (variety, grade) in TARGET_ITEMS_TEST.items():\n",
    "        mask = ((df[\"품목명\"] == item_name) &\n",
    "                (df[\"품종명\"] == variety) &\n",
    "                (df[grade_col] == grade))\n",
    "        sub = df[mask].copy()\n",
    "        sub[\"item_key\"] = item_name\n",
    "        records.append(sub)\n",
    "\n",
    "    non_empty = [r for r in records if len(r) > 0]\n",
    "    if not non_empty:\n",
    "        return pd.DataFrame()\n",
    "    df = pd.concat(non_empty, ignore_index=True)\n",
    "\n",
    "    df[\"평균가격(원)\"] = df.groupby(\"item_key\")[\"평균가격(원)\"].transform(fix_missing)\n",
    "\n",
    "    # 메타: 품목별 전체 평균으로 대체\n",
    "    meta = build_meta_feature(wholesale_raw, local_raw)\n",
    "    if not meta.empty:\n",
    "        price_cols = [c for c in [\"도매_price\", \"산지_price\"] if c in meta.columns]\n",
    "        if price_cols and \"item_key\" in meta.columns:\n",
    "            meta_avg = meta.groupby(\"item_key\")[price_cols].mean().reset_index()\n",
    "            df = df.merge(meta_avg, on=\"item_key\", how=\"left\")\n",
    "\n",
    "    # Lag / Rolling\n",
    "    df = df.sort_values([\"item_key\", \"time_idx\"]).reset_index(drop=True)\n",
    "    for lag in [1, 2, 3, 6, 9]:\n",
    "        df[f\"lag_{lag}\"] = df.groupby(\"item_key\")[\"평균가격(원)\"].shift(lag)\n",
    "    for w in [3, 6, 9]:\n",
    "        df[f\"roll_mean_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).mean()))\n",
    "        df[f\"roll_std_{w}\"] = (\n",
    "            df.groupby(\"item_key\")[\"평균가격(원)\"]\n",
    "              .transform(lambda x: x.shift(1).rolling(w, min_periods=1).std().fillna(0)))\n",
    "\n",
    "    # 계절성: test는 시점 미상 → 중간값 사용\n",
    "    df[\"sin_month\"]  = np.sin(2 * np.pi * 6 / 12)\n",
    "    df[\"cos_month\"]  = np.cos(2 * np.pi * 6 / 12)\n",
    "    df[\"sin_decade\"] = np.sin(2 * np.pi * 2 / 3)\n",
    "    df[\"cos_decade\"] = np.cos(2 * np.pi * 2 / 3)\n",
    "\n",
    "    return df\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 7. TEST 추론\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def predict_test(models_by_horizon, test_df, train_df, feat_cols):\n",
    "    \"\"\"\n",
    "    models_by_horizon: {1: [lgb모델...], 2: [...], 3: [...]}\n",
    "    반환: {item_key: [pred_t1, pred_t2, pred_t3]}\n",
    "    \"\"\"\n",
    "    preds = {}\n",
    "    item_keys = list(TARGET_ITEMS.keys())\n",
    "\n",
    "    for item_key in item_keys:\n",
    "        item_enc = item_keys.index(item_key)\n",
    "        test_item  = test_df[test_df[\"item_key\"] == item_key].sort_values(\"time_idx\") if len(test_df) > 0 else pd.DataFrame()\n",
    "        train_item = train_df[train_df[\"item_key\"] == item_key].sort_values(\"time_idx\")\n",
    "\n",
    "        # 가장 최근 시점 피처 추출\n",
    "        if len(test_item) > 0:\n",
    "            last_row = test_item.iloc[[-1]]   # T순 (가장 최근)\n",
    "        else:\n",
    "            last_row = train_item.iloc[[-1]]  # train 마지막 행\n",
    "\n",
    "        pred_list = []\n",
    "        for horizon in [1, 2, 3]:\n",
    "            row_feat = []\n",
    "            for c in feat_cols:\n",
    "                val = last_row[c].values[0] if c in last_row.columns else 0.0\n",
    "                try:\n",
    "                    val = float(val)\n",
    "                except:\n",
    "                    val = 0.0\n",
    "                if np.isnan(val) or np.isinf(val):\n",
    "                    val = 0.0\n",
    "                row_feat.append(val)\n",
    "            row_feat.append(item_enc)\n",
    "            X = np.array(row_feat).reshape(1, -1)\n",
    "\n",
    "            # 앙상블: KFold 모델 평균\n",
    "            fold_preds = np.mean([m.predict(X)[0] for m in models_by_horizon[horizon]])\n",
    "            pred_list.append(max(fold_preds, 0))\n",
    "\n",
    "        preds[item_key] = pred_list\n",
    "\n",
    "    return preds\n",
    "\n",
    "# ──────────────────────────────────────────────────\n",
    "# 8. 메인\n",
    "# ──────────────────────────────────────────────────\n",
    "\n",
    "def main():\n",
    "    print(\"=\" * 55)\n",
    "    print(\"  농산물 가격 예측 — LightGBM 파이프라인\")\n",
    "    print(\"=\" * 55)\n",
    "\n",
    "    # ── 1. 로드\n",
    "    print(\"\\n[1/5] 데이터 로드 중...\")\n",
    "    train_raw        = load_train()\n",
    "    w_train, l_train = load_meta_train()\n",
    "\n",
    "    # ── 2. 전처리\n",
    "    print(\"[2/5] 전처리 중...\")\n",
    "    train_df  = preprocess_train(train_raw, w_train, l_train)\n",
    "    feat_cols = get_feat_cols(train_df)\n",
    "    print(f\"      피처 {len(feat_cols)}개: {feat_cols}\")\n",
    "    print(f\"      학습 행 수: {len(train_df)}\")\n",
    "\n",
    "    # ── 3. 학습 샘플 생성 & 모델 학습\n",
    "    print(\"\\n[3/5] LightGBM 학습 중...\")\n",
    "    models_by_horizon = {}\n",
    "    for horizon in [1, 2, 3]:\n",
    "        print(f\"  T+{horizon}순 모델 학습...\")\n",
    "        X, y = make_supervised(train_df, feat_cols, horizon)\n",
    "        print(f\"    샘플 수: {len(X)}\")\n",
    "        models_by_horizon[horizon] = train_lgbm(X, y, horizon)\n",
    "    print(\"  학습 완료!\")\n",
    "\n",
    "    # ── 4. 추론\n",
    "    print(\"\\n[4/5] TEST 추론 중...\")\n",
    "    sub = load_csv(SUB_PATH)\n",
    "\n",
    "    for idx in range(25):\n",
    "        print(f\"  TEST_{idx:02d} ...\", end=\" \")\n",
    "        test_raw         = load_test(idx)\n",
    "        w_test, l_test   = load_meta_test(idx)\n",
    "        test_df          = preprocess_test_single(test_raw, w_test, l_test)\n",
    "\n",
    "        preds = predict_test(models_by_horizon, test_df, train_df, feat_cols)\n",
    "\n",
    "        for item_key, pred_list in preds.items():\n",
    "            for t, pred_val in enumerate(pred_list, start=1):\n",
    "                sijeom   = f\"TEST_{idx:02d}+{t}순\"\n",
    "                row_mask = sub[\"시점\"] == sijeom\n",
    "                if row_mask.any() and item_key in sub.columns:\n",
    "                    sub.loc[row_mask, item_key] = pred_val\n",
    "        print(\"완료\")\n",
    "\n",
    "    # ── 5. 저장\n",
    "    print(\"\\n[5/5] 저장 중...\")\n",
    "    out_path = \"./submission.csv\"\n",
    "    sub.to_csv(out_path, index=False, encoding=\"utf-8-sig\")\n",
    "    print(f\"      저장 완료: {out_path}\")\n",
    "\n",
    "    # 최종 확인\n",
    "    print(\"\\n=== 최종 확인 ===\")\n",
    "    result = pd.read_csv(out_path, encoding=\"utf-8-sig\")\n",
    "    print(f\"0인 값: {(result.iloc[:,1:] == 0).sum().sum()}개\")\n",
    "    print(result.head(3).to_string())\n",
    "    print(\"\\n완료!\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()"
   ]
